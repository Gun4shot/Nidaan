# Model path — local HuggingFace cache or HF model ID
MODEL_PATH=BioMistral/BioMistral-7B

# Quantization (pick one)
USE_4BIT=true
USE_8BIT=false

# Device: auto, cuda, cpu
DEVICE=auto

# Generation
MAX_NEW_TOKENS=512
TEMPERATURE=0.3
TOP_P=0.9
REPETITION_PENALTY=1.1

# Flask
FLASK_PORT=5001
FLASK_DEBUG=false

# ── RAG: Embeddings ──────────────────────────────────────
# Default (domain-specific biomedical):
#   EMBEDDING_MODEL=pritamdeka/BioBERT-mnli-snli-scinli-scitail-mednli-stsb
# Alternative biomedical:
#   EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
# General purpose (fast, less accurate for medical):
#   EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=pritamdeka/BioBERT-mnli-snli-scinli-scitail-mednli-stsb
EMBEDDING_DEVICE=cpu

# ── RAG: Chunking ────────────────────────────────────────
# Chunk size in characters (~4 chars per token, so 2048 ≈ 512 tokens)
RAG_INDEX_DIR=rag_index
RAG_CHUNK_SIZE=2048
RAG_CHUNK_OVERLAP=400

# ── RAG: Retrieval ───────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.2
# Hybrid search combines dense (FAISS) + sparse (BM25) retrieval
RAG_HYBRID_SEARCH=true
RAG_BM25_WEIGHT=0.4
RAG_DENSE_WEIGHT=0.6

# ── RAG: Reranker ────────────────────────────────────────
# Cross-encoder reranker for improved relevance ranking
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_USE_RERANKER=true

# ── RAG: Auto-sync Scheduler ─────────────────────────────
# Set to true to auto-download WHO/CDC docs on startup
RAG_AUTO_SYNC=false
RAG_SYNC_INTERVAL_HOURS=24

# ── RAG: Medical Documents Folder ────────────────────────
MEDICAL_DOCS_DIR=medical_documents

# ── Gemini API (Stage 2 — Context Enricher) ─────────────
# Free tier: 1,500 requests/day, no credit card
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
