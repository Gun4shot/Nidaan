# Model path — local HuggingFace cache or HF model ID
MODEL_PATH=BioMistral/BioMistral-7B

# Quantization (pick one)
USE_4BIT=true
USE_8BIT=false

# Device: auto, cuda, cpu
DEVICE=auto

# Generation
MAX_NEW_TOKENS=512
TEMPERATURE=0.3
TOP_P=0.9
REPETITION_PENALTY=1.1

# Flask
FLASK_PORT=5000
FLASK_DEBUG=false

# ── RAG: Embeddings ──────────────────────────────────────
# Default (fast, general purpose):
#   EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Biomedical (better medical accuracy, larger):
#   EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
#   EMBEDDING_MODEL=microsoft/BiomedNLP-PubMedBERT-base-uncased-abstract-fulltext
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ── RAG: Chunking ────────────────────────────────────────
RAG_INDEX_DIR=rag_index
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100

# ── RAG: Retrieval ───────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.3

# ── RAG: Reranker ────────────────────────────────────────
# Cross-encoder reranker for improved relevance ranking
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_USE_RERANKER=true

# ── RAG: Auto-sync Scheduler ─────────────────────────────
# Set to true to auto-download WHO/CDC docs on startup
RAG_AUTO_SYNC=false
RAG_SYNC_INTERVAL_HOURS=24

# ── RAG: Medical Documents Folder ────────────────────────
MEDICAL_DOCS_DIR=medical_documents
